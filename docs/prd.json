        },
        "diretrizes_gerais": {
          "protecao_juridica": "DOCUMENTAÇÃO COMPLETA PARA PROTEÇÃO MÉDICO-LEGAL",
          "estilo_escrita": "TÉCNICA, SUCINTA E ORTOGRAFICAMENTE CORRETA",
          "terminologia": {
            "regra": "TERMOS TÉCNICOS MÉDICOS OBRIGATÓRIOS",
            "siglas": ["HAS", "DM", "DPOC", "IAM", "AVE", "TEP", "TVP", "FA", "ICC", "IRC"]
          },
          "alertas_visuais": {"cor": "VERMELHO", "conteudo": ["INTERAÇÕES MEDICAMENTOSAS", "SCORES DE RISCO", "CONTRAINDICAÇÕES"]}
        },
        "regras_geracao_texto": {
          "formato": "TEXTO CONTÍNUO",
          "inicio": "IDADE, SEXO, SINTOMA PRINCIPAL, TEMPO DE EVOLUÇÃO",
          "classificacao_temporal": {"agudo": "<24h", "subagudo": "1–7 dias", "cronico": ">7 dias"},
          "caracterizacao": ["fatores de melhora/piora", "medicações prévias relevantes", "sintomas associados"],
          "negativas_importantes": "negar explicitamente sinais de alarme pertinentes",
          "antecedentes": "comorbidades em siglas",
          "medicacoes": "apenas as relevantes para o quadro",
          "alergias": "sempre documentar ou negar",
          "exame_fisico": {
            "obrigatorio": ["PA", "FC", "FR", "TAX", "SpO2", "DXT se indicado"],
            "achados": "pertinentes + negativos relevantes",
            "formato": "objetivo e técnico"
          },
          "hipoteses_diagnosticas": {
            "quantidade": 3,
            "formato": "listar diagnósticos; detalhamento no final",
            "detalhamento_final": {"cid10": true, "justificativa": true, "scores": ["Wells", "CURB-65", "HEART", "Centor"]}
          },
          "condutas": {
            "medicacoes": {
              "formato": "nome genérico + dose + via + posologia",
              "alertas_vermelho": ["ajuste renal se TFG <60", "ajuste hepático se Child B/C", "interações principais", "contraindicações absolutas/relativas"]
            },
            "orientacoes": {
              "sinais_alarme": "específicos por diagnóstico",
              "documentacao_padrao": "PACIENTE ORIENTADO SOBRE SINAIS DE ALARME E RETORNO IMEDIATO SE NECESSÁRIO. VERBALIZOU COMPREENSÃO DAS ORIENTAÇÕES."
            },
            "criterios_alta_internacao": "objetivos e baseados em scores"
          },
          "observacoes_finais": {
            "informacoes_faltantes": "sempre identificar e documentar",
            "atestado": "dias quando indicado",
            "aviso_legal": "SISTEMA AUXILIAR – NÃO SUBSTITUI JULGAMENTO CLÍNICO MÉDICO"
          }
        }
      }
